model Person {
  id                     Int          @id @default(autoincrement())
  name                   String
  connectionsAsPersonOne Connection[] @relation("PersonOneConnections")
  connectionsAsPersonTwo Connection[] @relation("PersonTwoConnections")
}

model Connection {
  id               Int    @id @default(autoincrement())
  personOne        Int
  personTwo        Int
  personOneDetails Person @relation("PersonOneConnections", fields: [personOne], references: [id])
  personTwoDetails Person @relation("PersonTwoConnections", fields: [personTwo], references: [id])
}
